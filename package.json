    "validate": "node scripts/validate.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mbanderas/maestro-agora.git"
  },
  "homepage": "https://github.com/mbanderas/maestro-agora#readme",
