  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agent-skills",
    "maestro",
    "marketing",
    "copywriting",
    "codex",
    "claude-code",
    "cursor",
    "geo",
    "aeo"
